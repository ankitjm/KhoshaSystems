# Brevo (Sendinblue) API key — required for lead nurture emails
BREVO_API_KEY=your-brevo-api-key-here

# VAPID keys for web push notifications
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Admin API key for protected endpoints (/api/leads, /api/visitors, /api/stats, /api/push)
ADMIN_API_KEY=change-this-to-a-strong-random-key

# Email Monitor — IMAP credentials (Hostinger)
# Required to enable inbox monitoring for khosha.tech
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_USER=veda@khosha.tech
IMAP_PASS=your-imap-password

# Email Monitor — SMTP credentials (Hostinger) for sending replies
# Defaults to IMAP_USER/IMAP_PASS if not set
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
# SMTP_USER=hello@khosha.tech
# SMTP_PASS=your-smtp-password

# Server port (default: 3007)
# PORT=3007

# Deployment credentials (for scripts/deploy.mjs)
DEPLOY_HOST=147.93.111.188
DEPLOY_USER=root
DEPLOY_PASS=your-vps-password
