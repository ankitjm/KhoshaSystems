{
  "name": "kosha-systems",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerender.js",
    "build:fast": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "deploy": "vite build && node scripts/prerender.js && node scripts/deploy.mjs",
    "video:preview": "npx remotion studio --entry-point videos/index.ts",
    "video:render": "node videos/render.mjs",
    "video:render:demo": "node videos/render.mjs --config videos/configs/retaileros-demo.json",
    "video:render:product": "node videos/render.mjs --composition ProductDemo --skip-postprocess",
    "video:render:social": "node videos/render.mjs --composition SocialClip --skip-postprocess"
  },
  "dependencies": {
    "@emailjs/browser": "4.3.0",
    "@google/genai": "latest",
