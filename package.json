    "@remotion/cli": "^4.0.438",
    "@remotion/renderer": "^4.0.438",
    "@remotion/zod-types": "^4.0.438",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "framer-motion": "^12.23.26",
    "imap": "^0.8.19",
    "lucide-react": "^0.562.0",
    "nodemailer": "^8.0.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "6.22.3",
    "remotion": "^4.0.438",
    "ssh2": "^1.17.0",
    "web-push": "^3.6.7"
  },
